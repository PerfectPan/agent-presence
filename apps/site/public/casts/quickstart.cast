{"version":2,"width":92,"height":28,"title":"agent-presence quickstart (sanitized)","env":{"SHELL":"zsh","TERM":"xterm-256color"}}
[0.2,"o","$ "]
[0.6,"i","agent-presence --help"]
[0.7,"o","agent-presence --help\r\n"]
[1.1,"o","Usage: agent-presence <command> [options]\r\n"]
[1.2,"o","\r\n"]
[1.3,"o","Commands:\r\n"]
[1.4,"o","  setup        Install hooks, watchers, and configure the default provider\r\n"]
[1.5,"o","  url          Print the signature URL (default: magic-builder FaaS)\r\n"]
[1.6,"o","  status       Print script-safe local status\r\n"]
[1.7,"o","  usage        Token consumption over calendar-day windows\r\n"]
[1.8,"o","  update       Push a rendered update to the slot\r\n"]
[1.9,"o","  reset        Reset presence to 0\r\n"]
[2.0,"o","  uninstall    Remove hooks, watchers, and (optionally) credentials\r\n"]
[2.1,"o","  config       Show or set provider / render configuration\r\n"]
[2.2,"o","  hook         Invoke a hook directly (installed automatically by setup)\r\n"]
[2.3,"o","\r\n"]
[2.4,"o","Bare commands target the default 'magic-builder' provider.\r\n"]
[2.6,"o","Pass --provider feishu-signature for the direct l.garyyang.work preview.\r\n"]
[2.8,"o","\r\n"]
[3.0,"o","$ "]
[3.4,"i","agent-presence status"]
[3.5,"o","agent-presence status\r\n"]
[3.9,"o","{\r\n"]
[4.0,"o","  \"activeCount\": 1,\r\n"]
[4.1,"o","  \"value\": \"1 个 AI 牛马正在搬砖 | codex 1\",\r\n"]
[4.2,"o","  \"provider\": \"magic-builder\",\r\n"]
[4.3,"o","  \"remote\": { \"faas\": { \"title\": \"1 个 AI 牛马正在搬砖 | codex 1\", \"expireStrategy\": \"60s\" } }\r\n"]
[4.4,"o","}\r\n"]
[4.6,"o","\r\n"]
[5.0,"o","$ "]
[5.4,"i","agent-presence url"]
[5.5,"o","agent-presence url\r\n"]
[5.9,"o","https://magic.solutionsuite.cn/r?fid=<faasId>\r\n"]
[6.1,"o","\r\n"]
[6.3,"o","# The URL contains only an encoded slot helper, never credentials.\r\n"]
[6.5,"o","# Paste it into your Feishu profile signature as a custom link preview.\r\n"]
[6.7,"o","\r\n"]
[7.0,"o","$ "]
