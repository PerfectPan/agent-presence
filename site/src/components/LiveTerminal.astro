---
// The signature element: a terminal that replays an agent-presence session and
// resolves into the live Feishu signature badge. Pure CSS/JS, no deps.
---
<div class="term" data-term aria-label="agent-presence terminal replay">
  <div class="term__bar">
    <span class="lights"><i class="r"></i><i class="a"></i><i class="m"></i></span>
    <span class="term__title">agent-presence — zsh</span>
    <span class="term__live"><b></b>live</span>
  </div>
  <div class="term__body" data-body></div>
  <div class="sig" data-sig>
    <span class="sig__tag">飞书签名预览 · feishu signature</span>
    <div class="sig__row">
      <span class="sig__count" data-count>0</span>
      <span class="sig__text" data-sigtext>AI 牛马正在摸鱼中</span>
    </div>
    <div class="sig__meta">
      <span data-detail>—</span>
      <span class="sig__usage">今日 <b data-tok>0</b> · <em data-cost>$0.00</em></span>
    </div>
  </div>
</div>

<style>
  .term {
    /* self-contained: the terminal is always dark regardless of page theme */
    --t-text: #ecebf5;
    --t-dim: #aaa8c0;
    --t-faint: #6f6d86;
    --t-green: #34d399;
    --t-sky: #7dd3fc;
    --t-violet: #7cc3ff;
    --t-amber: #fbbf24;
    --t-border: rgba(255, 255, 255, .10);
    --t-grad: linear-gradient(115deg, #5b9bff, #56cff5 70%);
    width: 100%;
    border: 1px solid var(--t-border);
    border-radius: var(--ap-radius);
    background:
      radial-gradient(120% 120% at 0% 0%, rgba(37,99,235,.06), transparent 40%),
      linear-gradient(180deg, #100f1b, #0b0a12);
    box-shadow: var(--ap-shadow);
    overflow: hidden;
    font-family: var(--ap-font-mono);
  }
  .term__bar {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px;
    background: linear-gradient(180deg, #17162400, #0000), #15141f;
    border-bottom: 1px solid var(--t-border);
  }
  .lights { display: inline-flex; gap: 7px; }
  .lights i { width: 11px; height: 11px; border-radius: 50%; display: block; }
  .lights .r { background: #ff5f57; } .lights .a { background: #febc2e; } .lights .m { background: #28c840; }
  .term__title { color: var(--t-faint); font-size: 12.5px; letter-spacing: .02em; }
  .term__live {
    margin-left: auto; display: inline-flex; align-items: center; gap: 7px;
    font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--t-green);
  }
  .term__live b { width: 7px; height: 7px; border-radius: 50%; background: var(--t-green); box-shadow: 0 0 0 0 rgba(52,211,153,.55); animation: pulse 1.8s infinite; }
  @keyframes pulse { 0%{box-shadow:0 0 0 0 rgba(52,211,153,.5)} 70%{box-shadow:0 0 0 8px rgba(52,211,153,0)} 100%{box-shadow:0 0 0 0 rgba(52,211,153,0)} }

  .term__body {
    padding: 18px 20px 6px;
    min-height: 196px;
    font-size: 13.5px;
    line-height: 1.85;
    color: var(--t-dim);
  }
  .ln { white-space: pre-wrap; word-break: break-word; }
  .ln .pmt { color: var(--t-green); }
  .ln .cmd { color: var(--t-text); }
  .ln.muted { color: var(--t-faint); }
  .ln .ok { color: var(--t-green); }
  .ln .hl { color: var(--t-sky); }
  .ln .amber { color: var(--t-amber); }
  .caret { display: inline-block; width: 8px; height: 1.05em; transform: translateY(2px); background: var(--t-green); margin-left: 2px; animation: blink 1s steps(1) infinite; }
  @keyframes blink { 50% { opacity: 0; } }

  .sig {
    margin: 6px 16px 18px;
    border: 1px solid var(--t-border);
    border-radius: 12px;
    background: linear-gradient(180deg, rgba(37,99,235,.08), rgba(56,189,248,.05)), #0e0d17;
    padding: 14px 16px;
    opacity: 0; transform: translateY(8px);
    transition: opacity .5s ease, transform .5s ease;
  }
  .sig.show { opacity: 1; transform: none; }
  .sig__tag { font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: var(--t-violet); }
  .sig__row { display: flex; align-items: baseline; gap: 12px; margin-top: 8px; font-family: var(--ap-font-body); }
  .sig__count {
    font-family: var(--ap-font-display); font-weight: 700; font-size: 30px; line-height: 1;
    background: var(--t-grad); -webkit-background-clip: text; background-clip: text; color: transparent;
    min-width: 1ch;
  }
  .sig__text { color: var(--t-text); font-weight: 600; font-size: 15px; }
  .sig__meta { display: flex; flex-wrap: wrap; gap: 6px 14px; margin-top: 8px; font-size: 12.5px; color: var(--t-faint); font-family: var(--ap-font-mono); }
  .sig__usage b { color: var(--t-green); font-weight: 500; }
  .sig__usage em { color: var(--t-amber); font-style: normal; }
</style>

<script>
  const root = document.querySelector('[data-term]');
  if (root) {
    const body = root.querySelector('[data-body]') as HTMLElement;
    const sig = root.querySelector('[data-sig]') as HTMLElement;
    const elCount = root.querySelector('[data-count]') as HTMLElement;
    const elText = root.querySelector('[data-sigtext]') as HTMLElement;
    const elDetail = root.querySelector('[data-detail]') as HTMLElement;
    const elTok = root.querySelector('[data-tok]') as HTMLElement;
    const elCost = root.querySelector('[data-cost]') as HTMLElement;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const sleep = (ms: number) => new Promise((r) => setTimeout(r, reduce ? 0 : ms));

    function line(html = '', cls = '') {
      const el = document.createElement('div');
      el.className = 'ln' + (cls ? ' ' + cls : '');
      el.innerHTML = html;
      body.appendChild(el);
      return el;
    }
    async function type(prefix: string, cmd: string) {
      const el = line(`<span class="pmt">$</span> ${prefix}<span class="cmd"></span><span class="caret"></span>`);
      const span = el.querySelector('.cmd') as HTMLElement;
      const caret = el.querySelector('.caret') as HTMLElement;
      if (reduce) { span.textContent = cmd; caret.remove(); return; }
      for (const ch of cmd) { span.textContent += ch; await sleep(38); }
      caret.remove();
    }

    async function run() {
      body.innerHTML = '';
      sig.classList.remove('show');
      elCount.textContent = '0'; elText.textContent = 'AI 牛马正在摸鱼中';
      elDetail.textContent = '—'; elTok.textContent = '0'; elCost.textContent = '$0.00';

      await sleep(400);
      await type('', 'npm i -g @rivus/agent-presence');
      await sleep(260); line('<span class="ok">+</span> @rivus/agent-presence@0.6.0', 'muted');
      await sleep(420);
      await type('', 'agent-presence setup');
      await sleep(300);
      line('<span class="ok">✓</span> hooks installed · <span class="hl">codex claude gemini opencode pi</span>', 'muted');
      await sleep(220);
      line('<span class="ok">✓</span> signature linked · <span class="hl">magic-builder</span>', 'muted');
      await sleep(620);
      sig.classList.add('show');

      const agents = [
        { c: 1, who: 'claude', text: 'AI 牛马正在搬砖', detail: 'claude 1', tok: 68, cost: 158 },
        { c: 2, who: 'codex',  text: 'AI 牛马正在并行搬砖', detail: 'claude 1 · codex 1', tok: 134, cost: 231 },
        { c: 3, who: 'claude', text: 'AI 牛马正在并行搬砖', detail: 'claude 2 · codex 1', tok: 171, cost: 260 },
      ];
      for (const a of agents) {
        line(`<span class="muted">→</span> session start · <span class="hl">${a.who}</span>`, 'muted');
        elCount.textContent = String(a.c);
        elText.textContent = a.text;
        elDetail.textContent = a.detail;
        await countTo(elTok, a.tok, 'M');
        elCost.textContent = '$' + a.cost;
        await sleep(900);
      }
      await sleep(2600);
    }

    async function countTo(el: HTMLElement, target: number, suffix: string) {
      if (reduce) { el.textContent = target + suffix; return; }
      const start = Number((el.textContent || '0').replace(/[^\d.]/g, '')) || 0;
      const steps = 14;
      for (let i = 1; i <= steps; i++) {
        const v = Math.round(start + ((target - start) * i) / steps);
        el.textContent = v + suffix;
        await sleep(26);
      }
    }

    if (reduce) {
      // settle to the final populated state once; no looping
      run();
    } else {
      // loop only while the terminal is on-screen
      let visible = false;
      let running = false;
      const loop = async () => {
        if (running) return;
        running = true;
        while (visible) await run();
        running = false;
      };
      new IntersectionObserver((entries) => {
        visible = entries[0].isIntersecting;
        if (visible) loop();
      }, { threshold: 0 }).observe(root);
    }
  }
</script>
