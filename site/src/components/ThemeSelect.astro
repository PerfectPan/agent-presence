---
// Replaces Starlight's native <select> theme picker with a custom icon toggle
// (no OS-native dropdown). Toggles between light and dark.
---
<starlight-theme-toggle>
  <button class="ap-theme" type="button" aria-label="Toggle theme" title="切换主题">
    <svg class="ico ico--moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
    <svg class="ico ico--sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
    </svg>
  </button>
</starlight-theme-toggle>

<script is:inline>
  if (!customElements.get('starlight-theme-toggle'))
  customElements.define(
    'starlight-theme-toggle',
    class extends HTMLElement {
      connectedCallback() {
        const btn = this.querySelector('button');
        btn.addEventListener('click', () => {
          const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          try { localStorage.setItem('starlight-theme', next); } catch {}
          document.documentElement.dataset.theme = next;
        });
      }
    },
  );
</script>
