---
import BrandIcon from './BrandIcon.astro';
const { download = 'Download SVG', colors = 'Colors', type = 'Type' } = Astro.props;
const swatches = [
  { name: 'Blue', hex: '#2563eb' },
  { name: 'Sky', hex: '#38bdf8' },
  { name: 'Live', hex: '#34d399' },
  { name: 'Ink', hex: '#15171f' },
  { name: 'Canvas', hex: '#f7f8fb', ring: true },
];
const faces = [
  { role: 'Display', face: 'Space Grotesk' },
  { role: 'Body', face: 'Inter' },
  { role: 'Mono', face: 'JetBrains Mono' },
];
---
<div class="bs not-content">
  <div class="bs__mark">
    <BrandIcon size={84} />
    <a class="bs__dl" href="/favicon.svg" download="agent-presence.svg">{download} ↓</a>
  </div>

  <p class="bs__label">{colors}</p>
  <div class="bs__swatches">
    {swatches.map((s) => (
      <div class="bs__sw">
        <span class="bs__chip" style={`background:${s.hex};${s.ring ? 'box-shadow:inset 0 0 0 1px var(--ap-border);' : ''}`}></span>
        <span class="bs__hex">{s.hex}</span>
        <span class="bs__name">{s.name}</span>
      </div>
    ))}
  </div>

  <p class="bs__label">{type}</p>
  <div class="bs__faces">
    {faces.map((f) => (
      <div class="bs__face">
        <span class="bs__role">{f.role}</span>
        <span class="bs__facename" style={`font-family:${f.face === 'JetBrains Mono' ? 'var(--ap-font-mono)' : f.face === 'Inter' ? 'var(--ap-font-body)' : 'var(--ap-font-display)'}`}>{f.face}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .bs { margin: 1.5rem 0; }
  .bs__mark {
    display: flex; align-items: center; gap: 20px;
    padding: 24px; border: 1px solid var(--sl-color-hairline); border-radius: 16px;
    background: linear-gradient(120% 140% at 0% 0%, rgba(37,99,235,.06), transparent 60%), var(--sl-color-bg);
  }
  .bs__dl {
    font: 600 13px/1 var(--ap-font-mono); text-decoration: none;
    color: var(--sl-color-text-accent); padding: 8px 14px; border: 1px solid var(--sl-color-hairline); border-radius: 10px;
    transition: background-color .15s, border-color .15s;
  }
  .bs__dl:hover { background: var(--sl-color-accent-low); border-color: var(--sl-color-accent); }
  .bs__label { font: 600 11px/1 var(--ap-font-mono); letter-spacing: .16em; text-transform: uppercase; color: var(--sl-color-gray-3); margin: 1.6rem 0 .6rem; }
  .bs__swatches { display: flex; flex-wrap: wrap; gap: 12px; }
  .bs__sw { display: flex; flex-direction: column; gap: 4px; }
  .bs__chip { width: 76px; height: 48px; border-radius: 10px; display: block; }
  .bs__hex { font: 12px/1 var(--ap-font-mono); color: var(--sl-color-white); }
  .bs__name { font: 11px/1 var(--ap-font-mono); color: var(--sl-color-gray-3); }
  .bs__faces { display: flex; flex-wrap: wrap; gap: 10px; }
  .bs__face { border: 1px solid var(--sl-color-hairline); border-radius: 10px; padding: 12px 16px; }
  .bs__role { display: block; font: 11px/1 var(--ap-font-mono); color: var(--sl-color-gray-3); margin-bottom: 6px; }
  .bs__facename { font-size: 18px; color: var(--sl-color-white); }
</style>
